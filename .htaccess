# ----------------------------------------------------------------------
# 1. SECURITY & PERFORMANCE BASICS
# ----------------------------------------------------------------------
# Mencegah akses directory browsing
Options -Indexes
Options +FollowSymlinks

# Menyembunyikan identitas server
ServerSignature Off

# ----------------------------------------------------------------------
# 2. FIREWALL & REWRITE ENGINE (CODEIGNITER 4 CORE)
# ----------------------------------------------------------------------
<IfModule mod_rewrite.c>
    RewriteEngine On

    # --- [NEW] FORCE HTTPS REDIRECT ---
    # Memastikan semua traffic masuk lewat jalur terenkripsi SSL
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # --- [START] FIREWALL: BLOKIR BAD BOTS & SCANNERS ---
    RewriteCond %{HTTP_USER_AGENT} ^$ [OR]
    RewriteCond %{HTTP_USER_AGENT} (sqlmap|nmap|nikto|wikto|sf|inject|nessus|metis|arachni|netsparker) [NC,OR]
    RewriteCond %{HTTP_USER_AGENT} (libwww-perl|python|wget|curl|scan|java|winhttp|clshttp|loader) [NC,OR]
    RewriteCond %{HTTP_USER_AGENT} (acunetix|havij|appscan|burp|zaproxy) [NC]
    RewriteRule ^(.*)$ - [F,L]

    # Blokir URL Jahat (XSS & SQL Injection)
    RewriteCond %{QUERY_STRING} (proc/self/environ) [NC,OR]
    RewriteCond %{QUERY_STRING} (mosConfig_[a-zA-Z_]{1,21}(=|\%3D)) [NC,OR]
    RewriteCond %{QUERY_STRING} (base64_encode|base64_decode) [NC,OR]
    RewriteCond %{QUERY_STRING} (<|%3C)([^s]*s)+cript.*(>|%3E) [NC,OR]
    RewriteCond %{QUERY_STRING} (GLOBALS|REQUEST)(=|\[|%) [NC,OR]
    RewriteCond %{QUERY_STRING} (boot\.ini|etc/passwd|self/environ) [NC]
    RewriteRule ^(.*)$ - [F,L]

    # Blokir Request Method yang tidak aman
    RewriteCond %{REQUEST_METHOD} ^(TRACE|TRACK|PUT|DELETE)
    RewriteRule .* - [F]
    # --- [END] FIREWALL ---

    # --- [START] CODEIGNITER 4 RULES ---
    # Redirect Trailing Slashes (Menghapus / di akhir URL)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # Mengarahkan semua request ke index.php (Front Controller)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.php?/$1 [L]

    # Memastikan Authorization Header terbaca (untuk API/JWT)
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
    # --- [END] CODEIGNITER 4 RULES ---
</IfModule>

# Fallback jika mod_rewrite mati
<IfModule !mod_rewrite.c>
    ErrorDocument 404 index.php
</IfModule>

# ----------------------------------------------------------------------
# 3. PROTEKSI FILE SISTEM & SENSITIF
# ----------------------------------------------------------------------
<FilesMatch "^\.|\.(env|json|lock|git|yml|log|xml|conf|ini)$">
    <If "%{REQUEST_URI} !~ m#^/sitemap\.xml$#">
        Require all denied
    </If>
</FilesMatch>

# ----------------------------------------------------------------------
# 4. SECURITY HEADERS (HARDENING)
# ----------------------------------------------------------------------
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set X-Content-Type-Options "nosniff"
    # Ditambahkan 'preload' agar lebih aman sesuai standar audit
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    Header always edit Set-Cookie (.*) "$1; HttpOnly; Secure; SameSite=Lax"
    
    # CSP Gabungan (Akses Lokal + FB + Google + CDN)
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.google.com https://www.gstatic.com https://connect.facebook.net https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; img-src 'self' data: https:; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com data:; frame-src 'self' https://www.google.com https://maps.google.com https://www.facebook.com https://web.facebook.com; connect-src 'self' https://www.google.com https://www.gstatic.com;"


    # Menghapus identitas teknologi
    Header unset X-Powered-By
    Header always unset X-Powered-By
    Header unset X-Pingback
</IfModule>

# ----------------------------------------------------------------------
# 5. PERFORMA (KOMPRESI & CACHE)
# ----------------------------------------------------------------------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain text/html text/xml text/css application/xml application/xhtml+xml application/rss+xml application/javascript application/x-javascript image/svg+xml font/ttf font/otf font/woff font/woff2
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"
    
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType video/mp4 "access plus 1 year"
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType text/javascript "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
</IfModule>